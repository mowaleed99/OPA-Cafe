# ─────────────────────────────────────────────────────────────────────────────
# OPA Cafe — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env (it is already in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (found in: Project Settings → API → Project URL)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anonymous / public key (found in: Project Settings → API → anon public)
# This key is safe to ship in client-side code; RLS enforces access control.
VITE_SUPABASE_ANON_KEY="your-anon-key-here"
